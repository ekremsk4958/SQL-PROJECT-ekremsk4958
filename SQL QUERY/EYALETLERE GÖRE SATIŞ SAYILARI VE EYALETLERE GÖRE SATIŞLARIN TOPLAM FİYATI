---EYALETLERE GÖRE SATIŞ SAYILARI VE EYALETLERE GÖRE SATIŞLARIN TOPLAM FİYATI 
SELECT TOP 10
COUNT(0.order_id) AS SIPARIS_SAYISI ,P.product_category_name, SUM(OI. price)AS TOPLAM_FIYAT
FROM ORDER_ITEM OI
INNER JOIN ORDERS O ON 0. order_id=OI. order_id
INNER JOIN PRODUCT_ P ON P.product_id=OI.product_id
GROUP BY P.product_category_name
ORDER BY COUNT(0. order_id) DESC
